<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="ManpWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ManpWinUI"
    xmlns:converters="using:ManpWinUI.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Theme-Specific Side Panel Backgrounds -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Light theme uses default system brush -->
                    <SolidColorBrush x:Key="SidePanelBackgroundBrush" Color="{ThemeResource LayerFillColorDefault}" />
                    <SolidColorBrush x:Key="CommandBarBackground" Color="{ThemeResource LayerFillColorDefault}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- Dark theme uses much darker gray - RGB(18, 18, 18) -->
                    <SolidColorBrush x:Key="SidePanelBackgroundBrush" Color="#121212" />
                    <SolidColorBrush x:Key="CommandBarBackground" Color="#1E1E1E" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <!-- System theme uses default -->
                    <SolidColorBrush x:Key="SidePanelBackgroundBrush" Color="{ThemeResource LayerFillColorDefault}" />
                    <SolidColorBrush x:Key="CommandBarBackground" Color="{ThemeResource LayerFillColorDefault}" />
                </ResourceDictionary>

                <!-- Ocean Blue theme moved to Themes/OceanBlue.xaml - loaded dynamically -->
            </ResourceDictionary.ThemeDictionaries>

            <!-- Other app resources here -->

            <!-- Converters -->
            <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
            <converters:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsedConverter"/>
            <converters:JuliaModeTextConverter x:Key="JuliaModeTextConverter"/>
            <converters:BoolToStarGlyphConverter x:Key="BoolToStarGlyphConverter"/>
            <converters:BoolToStarColorConverter x:Key="BoolToStarColorConverter"/>
            <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
            <converters:BoolToButtonStyleConverter x:Key="BoolToButtonStyleConverter"/>
            <!-- Week 7 Converters -->
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
            <converters:EnumToIntConverter x:Key="EnumToIntConverter"/>

            <Color x:Key="Primary">#512BD4</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
            <SolidColorBrush x:Key="WhiteBrush" Color="White" />
            <SolidColorBrush x:Key="BlackBrush" Color="Black" />

            <x:Double x:Key="AppFontSize">14</x:Double>

            <Style x:Key="MyLabel" TargetType="TextBlock">
                <Setter Property="Foreground"
                        Value="{StaticResource PrimaryBrush}" />
            </Style>

            <Style x:Key="Action" TargetType="Button">
                <Setter Property="FontSize"
                        Value="{StaticResource AppFontSize}" />
                <Setter Property="Padding"
                        Value="14,10" />
            </Style>

            <Style x:Key="PrimaryAction"
                   TargetType="Button"
                   BasedOn="{StaticResource Action}">
                <Setter Property="Background"
                        Value="{StaticResource PrimaryBrush}" />
                <Setter Property="CornerRadius"
                        Value="8" />
                <Setter Property="Foreground"
                        Value="{StaticResource WhiteBrush}" />
            </Style>

            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
