<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>C:\Users\Mark\source\repos\ManpLab\AppPackages</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- MSIX Packaging Settings -->
    <PackageAction>Create</PackageAction>
    <GenerateAppInstallerFile>false</GenerateAppInstallerFile>
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>
    <PackageCertificateThumbprint>
    </PackageCertificateThumbprint>
    <AppxPackageDir>..\AppPackages\</AppxPackageDir>
    <AppxBundle>Never</AppxBundle>
    <AppxBundlePlatforms>x64</AppxBundlePlatforms>
    <AppInstallerUri>
    </AppInstallerUri>
    <HoursBetweenUpdateChecks>0</HoursBetweenUpdateChecks>
    <GenerateTestArtifacts>False</GenerateTestArtifacts>
    <AppxPackageTestDir>..\AppPackages\ManpWinUI_Test\</AppxPackageTestDir>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
