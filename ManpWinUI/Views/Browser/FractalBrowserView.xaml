<UserControl
    x:Class="ManpWinUI.Views.Browser.FractalBrowserView"
    x:Name="BrowserViewRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ManpWinUI.Views.Browser"
    xmlns:vm="using:ManpWinUI.ViewModels.Browser"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:FractalBrowserViewModel}">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Fractal Browser"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="16,12,16,8" />

        <!-- Search Box -->
        <TextBox
            Grid.Row="1"
            Margin="12,0,12,12"
            PlaceholderText="Search fractals..."
            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Fractal TreeView -->
        <ScrollViewer Grid.Row="2" Padding="8,0">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:FractalCategoryNode">
                        <Expander IsExpanded="{x:Bind IsExpanded, Mode=OneWay}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Margin="0,2">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Icon}" FontSize="14" />
                                    <TextBlock Text="{x:Bind Name}" 
                                               FontWeight="SemiBold" 
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsRepeater ItemsSource="{x:Bind Fractals}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FractalNode">
                                        <Button Content="{x:Bind DisplayName}"
                                                Command="{Binding SelectFractalCommand}"
                                                CommandParameter="{x:Bind}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="24,8,8,8"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Margin="0,1">
                                            <ToolTipService.ToolTip>
                                                <ToolTip MaxWidth="400">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="{x:Bind DisplayName}" 
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{x:Bind Description}" 
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{x:Bind Description, Converter={StaticResource NullToVisibilityConverter}}" />
                                                        <Border BorderThickness="0,1,0,0"
                                                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                Padding="0,8,0,0"
                                                                Visibility="{x:Bind Formula, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="Formula:" 
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock Text="{x:Bind Formula}" 
                                                                           FontFamily="Consolas"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </ToolTip>
                                            </ToolTipService.ToolTip>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </Expander>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Info Panel (Collapsible) -->
        <Expander Grid.Row="3"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  IsExpanded="True"
                  Visibility="{x:Bind ViewModel.SelectedFractal, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
            <Expander.Header>
                <TextBlock Text="ℹ️ Fractal Information"
                           FontWeight="SemiBold"
                           FontSize="12" />
            </Expander.Header>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="12"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0">
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" DataContext="{x:Bind ViewModel.SelectedFractal, Mode=OneWay}">
                        <!-- Fractal Name -->
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />

                        <!-- Description -->
                        <TextBlock Text="{Binding Description}"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Formula Section -->
                        <StackPanel Spacing="4" Visibility="{Binding Formula, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="Formula:"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    Padding="8"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding Formula}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True" />
                            </Border>
                        </StackPanel>

                        <!-- Category -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Category:"
                                       FontWeight="SemiBold"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{Binding Category}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Expander>
    </Grid>
</UserControl>
