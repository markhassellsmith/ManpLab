<UserControl
    x:Class="ManpWinUI.Views.Browser.FractalBrowserView"
    x:Name="BrowserViewRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ManpWinUI.Views.Browser"
    xmlns:vm="using:ManpWinUI.ViewModels.Browser"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:FractalBrowserViewModel}">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Fractal Browser"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="16,12,16,8" />

        <!-- Search Box -->
        <TextBox
            Grid.Row="1"
            Margin="12,0,12,12"
            PlaceholderText="Search fractals..."
            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Fractal TreeView -->
        <ScrollViewer Grid.Row="2" Padding="8,0">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:FractalCategoryNode">
                        <Expander IsExpanded="{x:Bind IsExpanded, Mode=OneWay}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Margin="0,2">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Icon}" FontSize="14" />
                                    <TextBlock Text="{x:Bind Name}" 
                                               FontWeight="SemiBold" 
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Expander.Header>
                            <ItemsRepeater ItemsSource="{x:Bind Fractals}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FractalNode">
                                        <Button Content="{x:Bind DisplayName}"
                                                Command="{Binding ElementName=BrowserViewRoot, Path=ViewModel.SelectFractalCommand}"
                                                CommandParameter="{x:Bind}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="24,8,8,8"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Margin="0,1"
                                                ToolTipService.ToolTip="{x:Bind Description}" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </Expander>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Status Footer -->
        <Border
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Padding="12,8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                Text="Click a fractal to load and render it"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
