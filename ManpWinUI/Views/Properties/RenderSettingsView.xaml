<UserControl
    x:Class="ManpWinUI.Views.Properties.RenderSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <StackPanel Spacing="16">

            <!-- Header -->
            <TextBlock 
                Text="Render Settings" 
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,0,0,8"/>

            <!-- Render Mode Selection -->
            <StackPanel Spacing="8">
                <TextBlock Text="Render Mode:" FontWeight="SemiBold"/>

                <RadioButton 
                    GroupName="RenderMode"
                    Content="Escape Time"
                    IsChecked="{x:Bind ViewModel.SelectedRenderMode, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=EscapeTime}"
                    Checked="RenderMode_Changed"/>

                <RadioButton 
                    GroupName="RenderMode"
                    Content="Smooth Coloring"
                    IsChecked="{x:Bind ViewModel.SelectedRenderMode, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=SmoothColoring}"
                    Checked="RenderMode_Changed"/>

                <RadioButton 
                    GroupName="RenderMode"
                    Content="Distance Estimation"
                    IsChecked="{x:Bind ViewModel.SelectedRenderMode, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=DistanceEstimation}"
                    Checked="RenderMode_Changed"/>

                <RadioButton 
                    GroupName="RenderMode"
                    Content="Orbit Trap"
                    IsChecked="{x:Bind ViewModel.SelectedRenderMode, Mode=TwoWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=OrbitTrap}"
                    Checked="RenderMode_Changed"/>

                <TextBlock 
                    Text="{x:Bind ViewModel.RenderModeDescription, Mode=OneWay}"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Quality Settings -->
            <StackPanel Spacing="12">
                <TextBlock Text="Quality Settings" FontWeight="SemiBold"/>

                <!-- Antialiasing -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Antialiasing:" FontSize="12"/>
                    <ComboBox 
                        SelectedIndex="{x:Bind ViewModel.AntialiasingLevel, Mode=TwoWay, Converter={StaticResource EnumToIntConverter}}"
                        SelectionChanged="Antialiasing_Changed"
                        HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="None (Fastest)"/>
                        <ComboBoxItem Content="2x MSAA"/>
                        <ComboBoxItem Content="4x MSAA (Recommended)"/>
                        <ComboBoxItem Content="8x MSAA (Best Quality)"/>
                    </ComboBox>
                    <TextBlock 
                        Text="{x:Bind ViewModel.AntialiasingDescription, Mode=OneWay}"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Smooth Coloring Toggle -->
                <CheckBox 
                    Content="Enable Smooth Coloring"
                    IsChecked="{x:Bind ViewModel.UseSmoothColoring, Mode=TwoWay}"
                    Checked="SmoothColoring_Changed"
                    Unchecked="SmoothColoring_Changed">
                    <CheckBox.Resources>
                        <x:String x:Key="ToolTipText">Eliminates color banding for smoother gradients</x:String>
                    </CheckBox.Resources>
                    <ToolTipService.ToolTip>
                        <ToolTip Content="{StaticResource ToolTipText}"/>
                    </ToolTipService.ToolTip>
                </CheckBox>

                <!-- Deep Zoom Toggle -->
                <CheckBox 
                    Content="Enable Deep Zoom (Arbitrary Precision)"
                    IsChecked="{x:Bind ViewModel.UseDeepZoom, Mode=TwoWay}"
                    Checked="DeepZoom_Changed"
                    Unchecked="DeepZoom_Changed">
                    <CheckBox.Resources>
                        <x:String x:Key="ToolTipText">Use high-precision math for extreme zoom levels (slower)</x:String>
                    </CheckBox.Resources>
                    <ToolTipService.ToolTip>
                        <ToolTip Content="{StaticResource ToolTipText}"/>
                    </ToolTipService.ToolTip>
                </CheckBox>
            </StackPanel>

            <!-- Resolution Note -->
            <Border 
                Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock 
                        Text="ℹ️ Resolution Settings" 
                        FontWeight="SemiBold"
                        FontSize="12"/>
                    <TextBlock 
                        Text="Image resolution is configured in the Parameters tab under 'Image Resolution' section."
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Reset Button -->
            <Button 
                Content="Reset to Defaults"
                Click="ResetButton_Click"
                HorizontalAlignment="Stretch"
                Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
