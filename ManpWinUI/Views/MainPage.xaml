<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="Page"
    x:Class="ManpWinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ManpWinUI.Views"
    xmlns:vm="using:ManpWinUI.ViewModels"
    xmlns:models="using:ManpWinUI.Models"
    xmlns:browser="using:ManpWinUI.Views.Browser"
    xmlns:properties="using:ManpWinUI.Views.Properties"
    xmlns:settings="using:ManpWinUI.Views.Settings"
    xmlns:animation="using:ManpWinUI.Views.Animation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    KeyDown="Page_KeyDown">

    <!-- KeyboardAccelerators removed - handled in Page_KeyDown to avoid automatic tooltips -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Toolbar -->
            <RowDefinition Height="*" />
            <!-- Main Content (Fractal + Side Panel) -->
            <RowDefinition Height="Auto" />
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right"
                    Background="{ThemeResource AppBarBackground}">
            <AppBarButton
                Icon="Play"
                Label="Render"
                IsEnabled="True"
                Command="{x:Bind ViewModel.RenderCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Render fractal (Ctrl+R)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton
                Icon="Refresh"
                Label="Reset View"
                Command="{x:Bind ViewModel.ResetViewCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Reset to default view (Space)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Icon="ZoomIn"
                Label="Zoom In"
                Command="{x:Bind ViewModel.ZoomInCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Zoom in 2x (+)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton
                Icon="ZoomOut"
                Label="Zoom Out"
                Command="{x:Bind ViewModel.ZoomOutCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Zoom out 2x (-)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton Label="Pan">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7C2;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Pan with arrow keys: ← → ↑ ↓" IsEnabled="False" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Or right-click and drag on image" IsEnabled="False" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Pan view (Arrow keys or right-click drag)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <!-- Navigation History Buttons (Week 8) -->
            <AppBarButton
                Label="Back"
                Command="{x:Bind ViewModel.UndoNavigationCommand}"
                IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72B;" />
                </AppBarButton.Icon>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Go back in navigation history (Ctrl+Z)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton
                Label="Forward"
                Command="{x:Bind ViewModel.RedoNavigationCommand}"
                IsEnabled="{x:Bind ViewModel.CanRedo, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72A;" />
                </AppBarButton.Icon>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Go forward in navigation history (Ctrl+Y)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Icon="Save"
                Label="Save Image"
                IsEnabled="{x:Bind ViewModel.FractalImage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Save Image..." Icon="Save" Click="SaveImageWithDialog_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="S" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Copy to Clipboard" Icon="Copy" Click="CopyToClipboard_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="C" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Save or copy fractal image" />
                </ToolTipService.ToolTip>
            </AppBarButton>
        </CommandBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Bind ViewModel.BrowserPanelWidth, Mode=OneWay, Converter={StaticResource DoubleToGridLengthConverter}}" />
                <!-- Left Panel (Browser/Bookmarks) - width persisted -->
                <ColumnDefinition Width="Auto" />
                <!-- GridSplitter for left panel -->
                <ColumnDefinition Width="*" />
                <!-- Fractal Display -->
                <ColumnDefinition Width="Auto" />
                <!-- GridSplitter for properties panel -->
                <ColumnDefinition Width="{x:Bind ViewModel.PropertiesPanelWidth, Mode=OneWay, Converter={StaticResource DoubleToGridLengthConverter}}" />
                <!-- Properties Panel - width persisted -->
            </Grid.ColumnDefinitions>

            <!-- Left Panel with Browser and Bookmarks Tabs -->
            <Grid Grid.Column="0"
                  Visibility="{x:Bind ViewModel.IsBrowserPanelVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Background="{ThemeResource SidePanelBackgroundBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Header with collapse button -->
                    <RowDefinition Height="*" />
                    <!-- Tabbed content -->
                </Grid.RowDefinitions>

                <!-- Left Panel Header -->
                <Grid Grid.Row="0"
                      Padding="12,8"
                      Background="{ThemeResource SidePanelBackgroundBrush}"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,0,0,1">
                    <TextBlock Text="Explorer"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Content="&#xE76C;"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{x:Bind ViewModel.ToggleBrowserPanelCommand}"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Collapse explorer panel (Ctrl+B)" />
                </Grid>

                <!-- Tabbed Content -->
                <TabView Grid.Row="1">
                    <TabView.Resources>
                        <Style TargetType="TabViewItem">
                            <Setter Property="FontSize" Value="11" />
                        </Style>
                    </TabView.Resources>
                    <!-- Browser Tab -->
                    <TabViewItem Header="Browser">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Library" />
                        </TabViewItem.IconSource>
                        <browser:FractalBrowserView x:Name="BrowserView" />
                    </TabViewItem>

                    <!-- Bookmarks Tab -->
                    <TabViewItem Header="Bookmarks">
                        <TabViewItem.IconSource>
                            <SymbolIconSource Symbol="Favorite" />
                        </TabViewItem.IconSource>
                        <ScrollViewer Padding="16">
                            <StackPanel Spacing="12">
                                <!-- Save Current View -->
                                <StackPanel Spacing="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" CornerRadius="8">
                                    <TextBlock Text="Save Current View" FontWeight="SemiBold" />
                                    <TextBox x:Name="NewBookmarkNameTextBox"
                                            PlaceholderText="Enter bookmark name..."
                                            Header="Name" />
                                    <Button Command="{x:Bind ViewModel.SaveCurrentAsBookmarkCommand}"
                                           CommandParameter="{x:Bind NewBookmarkNameTextBox.Text, Mode=OneWay}"
                                           HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE710;" FontSize="16" />
                                            <TextBlock Text="Save Bookmark" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <MenuFlyoutSeparator />

                                <!-- Bookmarks List -->
                                <Grid>
                                    <TextBlock Text="Saved Locations" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button Content="{x:Bind ViewModel.BookmarkFilterLabel, Mode=OneWay}"
                                            Command="{x:Bind ViewModel.ToggleFavoritesFilterCommand}"
                                            HorizontalAlignment="Right"
                                            ToolTipService.ToolTip="Toggle favorites filter" />
                                </Grid>

                                <ListView ItemsSource="{x:Bind ViewModel.FilteredBookmarks, Mode=OneWay}"
                                         SelectedItem="{x:Bind ViewModel.SelectedBookmark, Mode=TwoWay}"
                                         SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:FractalBookmark">
                                            <Grid Padding="8" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Favorite Star Button -->
                                                <Button Grid.Column="0"
                                                       Content="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToStarGlyphConverter}}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToStarColorConverter}}"
                                                       Command="{Binding ElementName=Page, Path=ViewModel.ToggleBookmarkFavoriteCommand}"
                                                       CommandParameter="{x:Bind}"
                                                       Style="{StaticResource SubtleButtonStyle}"
                                                       ToolTipService.ToolTip="Toggle favorite" />

                                                <!-- Bookmark Info -->
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{x:Bind CoordinateDisplay}"
                                                              FontSize="11"
                                                              Opacity="0.7"
                                                              TextWrapping="Wrap" />
                                                    <TextBlock Text="{x:Bind Description}"
                                                              FontSize="10"
                                                              Opacity="0.6"
                                                              TextWrapping="Wrap"
                                                              Visibility="{x:Bind Description, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}" />
                                                </StackPanel>

                                                <!-- Load Button -->
                                                <Button Grid.Column="2"
                                                       Content="&#xE768;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Command="{Binding ElementName=Page, Path=ViewModel.LoadBookmarkCommand}"
                                                       CommandParameter="{x:Bind}"
                                                       Style="{StaticResource SubtleButtonStyle}"
                                                       ToolTipService.ToolTip="Load this bookmark" />

                                                <!-- Delete Button (not for presets) -->
                                                <Button Grid.Column="3"
                                                       Content="&#xE74D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Command="{Binding ElementName=Page, Path=ViewModel.DeleteBookmarkCommand}"
                                                       CommandParameter="{x:Bind}"
                                                       Style="{StaticResource SubtleButtonStyle}"
                                                       Visibility="{x:Bind IsPreset, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                                       ToolTipService.ToolTip="Delete bookmark" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>
                </TabView>
            </Grid>

            <!-- Collapsed Left Panel Button -->
            <Button Grid.Column="0"
                    Visibility="{x:Bind ViewModel.IsBrowserPanelVisible, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                    Content="&#xE76B;"
                    FontFamily="Segoe MDL2 Assets"
                    Command="{x:Bind ViewModel.ToggleBrowserPanelCommand}"
                    VerticalAlignment="Top"
                    Margin="4"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Expand explorer panel (Ctrl+B)"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1" />

            <!-- GridSplitter for Left Panel -->
            <Border Grid.Column="1"
                    Width="4"
                    Visibility="{x:Bind ViewModel.IsBrowserPanelVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    PointerEntered="BrowserSplitter_PointerEntered"
                    PointerExited="BrowserSplitter_PointerExited"
                    PointerPressed="BrowserSplitter_PointerPressed"
                    PointerMoved="BrowserSplitter_PointerMoved"
                    PointerReleased="BrowserSplitter_PointerReleased" />

            <!-- Fractal Canvas -->
            <Grid x:Name="FractalDisplayGrid"
                  Grid.Column="2"
                  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                  PointerPressed="FractalImage_PointerPressed"
                  PointerMoved="FractalImage_PointerMoved"
                  PointerReleased="FractalImage_PointerReleased"
                  PointerWheelChanged="FractalImage_PointerWheelChanged">
                <!-- Fractal Image Display -->
                <Viewbox x:Name="FractalViewbox" Stretch="Uniform" SizeChanged="FractalViewbox_SizeChanged">
                    <Image
                        x:Name="FractalImage"
                        Source="{x:Bind ViewModel.FractalImage, Mode=OneWay}"
                        Stretch="None" />
                </Viewbox>

                <!-- Selection Rectangle Overlay -->
                <Canvas x:Name="SelectionCanvas" Canvas.ZIndex="10">
                    <Rectangle
                        x:Name="SelectionRectangle"
                        Stroke="Cyan"
                        StrokeThickness="3"
                        Fill="#40FFFFFF"
                        Visibility="Collapsed"
                        StrokeDashArray="5,3">
                        <Rectangle.Shadow>
                            <ThemeShadow />
                        </Rectangle.Shadow>
                    </Rectangle>
                </Canvas>

                <!-- Coordinate Axes Overlay (for Mandelbrot/Julia only, not for Hailstone) -->
                <Canvas x:Name="CoordinateAxesCanvas"
                    Canvas.ZIndex="5"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.ShowMandelbrotAxes, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    SizeChanged="CoordinateAxesCanvas_SizeChanged">
                </Canvas>

                <!-- Hailstone Labels Overlay -->
                <Canvas x:Name="HailstoneLabelsCanvas"
                    Canvas.ZIndex="6"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.IsHailstoneMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    SizeChanged="HailstoneLabelsCanvas_SizeChanged">
                </Canvas>

                <!-- Welcome Overlay (shown when no fractal is rendered) -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.FractalImage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock
                        Text="ManpLab - Fractal Explorer"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="WinUI Interface, MVVM Architecture, C++ Computation Engine"
                        FontSize="16"
                        Opacity="0.7"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Adjust parameters in the side panel and click 'Render' to generate your first fractal!"
                        FontSize="14"
                        Opacity="0.6"
                        HorizontalAlignment="Center"
                        TextWrapping="Wrap"
                        MaxWidth="400" />
                </StackPanel>

                <!-- Progress Overlay -->
                <Grid
                    Background="{ThemeResource SystemControlAcrylicElementBrush}"
                    Visibility="{x:Bind ViewModel.IsRendering, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Canvas.ZIndex="100">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">

                        <!-- Progress Ring -->
                        <ProgressRing
                            IsActive="True"
                            Width="60"
                            Height="60" />

                        <TextBlock
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            FontSize="16"
                            HorizontalAlignment="Center"
                            TextWrapping="Wrap"
                            MaxWidth="400"
                            TextAlignment="Center" />
                        <ProgressBar
                            Value="{x:Bind ViewModel.RenderProgress, Mode=OneWay}"
                            Width="300"
                            Maximum="100" />

                        <!-- Render Control Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Button
                                Command="{x:Bind ViewModel.StopRenderCommand}"
                                Content="Stop Render"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="120">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Escape" />
                                </Button.KeyboardAccelerators>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- GridSplitter for Properties Panel -->
            <Border Grid.Column="3"
                    Width="4"
                    Visibility="{x:Bind ViewModel.IsPropertiesPanelVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    PointerEntered="PropertiesSplitter_PointerEntered"
                    PointerExited="PropertiesSplitter_PointerExited"
                    PointerPressed="PropertiesSplitter_PointerPressed"
                    PointerMoved="PropertiesSplitter_PointerMoved"
                    PointerReleased="PropertiesSplitter_PointerReleased" />

            <!-- Properties Panel with Tabs -->
            <Grid Grid.Column="4"
                          Visibility="{x:Bind ViewModel.IsPropertiesPanelVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Background="{ThemeResource SidePanelBackgroundBrush}"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="1,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!-- Header with collapse button -->
                            <RowDefinition Height="*" />
                            <!-- Properties content -->
                        </Grid.RowDefinitions>

                        <!-- Properties Panel Header -->
                        <Grid Grid.Row="0"
                              Padding="12,8"
                              Background="{ThemeResource SidePanelBackgroundBrush}"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <TextBlock Text="Properties"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="&#xE76C;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Command="{x:Bind ViewModel.TogglePropertiesPanelCommand}"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Collapse properties panel (Ctrl+P)" />
                        </Grid>

                        <!-- Properties Content -->
                        <TabView x:Name="PropertiesTabView"
                                 Grid.Row="1"
                                 SelectedIndex="{x:Bind ViewModel.SelectedPropertiesTabIndex, Mode=TwoWay}">
                            <TabView.Resources>
                                <Style TargetType="TabViewItem">
                                    <Setter Property="FontSize" Value="10" />
                                </Style>
                            </TabView.Resources>
                            <!-- Parameters Tab -->
                            <TabViewItem Header="Parameters">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Setting" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Parameters - Fractal settings and coordinates" />
                                </ToolTipService.ToolTip>
                                <ScrollViewer Padding="16">
                                    <StackPanel Spacing="12">
                                        <!-- Dynamic Parameter Editor -->
                                        <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                Background="{ThemeResource LayerFillColorAltBrush}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Dynamic Parameters"
                                                           FontWeight="SemiBold"
                                                           FontSize="14" />
                                                <TextBlock Text="Parameters for selected fractal will appear below:"
                                                           FontSize="12"
                                                           Opacity="0.7"
                                                           TextWrapping="Wrap" />
                                                <properties:ParameterEditorView x:Name="ParameterEditor" />
                                            </StackPanel>
                                        </Border>

                                        <MenuFlyoutSeparator />

                                        <!-- Fractal Type Selection -->
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Fractal Type" FontWeight="SemiBold" />
                                            <ComboBox
                                        SelectedItem="{x:Bind ViewModel.SelectedFractalType, Mode=OneWay}"
                                        HorizontalAlignment="Stretch">
                                                <!-- Classic Fractals -->
                                                <x:String>Mandelbrot</x:String>
                                                <x:String>BurningShip</x:String>
                                                <x:String>Tricorn</x:String>
                                                <x:String>Phoenix</x:String>
                                                <!-- Multibrot Family -->
                                                <x:String>Multibrot3</x:String>
                                                <x:String>Multibrot4</x:String>
                                                <x:String>Multibrot5</x:String>
                                                <!-- Newton Method -->
                                                <x:String>Newton</x:String>
                                                <x:String>Nova</x:String>
                                                <!-- Magnet Fractals -->
                                                <x:String>Magnet1</x:String>
                                                <x:String>Magnet2</x:String>
                                                <!-- Julia Presets -->
                                                <x:String>JuliaSanMarco</x:String>
                                                <x:String>JuliaDouadyRabbit</x:String>
                                                <x:String>JuliaSiegelDisk</x:String>
                                                <!-- Hailstone (special) -->
                                                <x:String>Hailstone</x:String>
                                            </ComboBox>
                                        </StackPanel>

                                        <MenuFlyoutSeparator />

                                        <!-- Iteration Mode (Standard/Julia) -->
                                        <StackPanel Spacing="4"
                                            Visibility="{x:Bind ViewModel.ShowIterationModeSelector, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Iteration Mode" FontWeight="SemiBold" />
                                            <ComboBox
                                        SelectedItem="{x:Bind ViewModel.SelectedIterationMode, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch">
                                                <x:String>Standard</x:String>
                                                <x:String>Julia</x:String>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Julia Parameters (visible only when Iteration Mode = Julia) -->
                                        <StackPanel Spacing="8"
                                            Visibility="{x:Bind ViewModel.IsJuliaMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Julia Constant (c)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Real Part (c_x)" />
                                                <NumberBox Value="{x:Bind ViewModel.JuliaCX, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="0.01"
                                                   LargeChange="0.1"
                                                   Minimum="-2"
                                                   Maximum="2" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Imaginary Part (c_y)" />
                                                <NumberBox Value="{x:Bind ViewModel.JuliaCY, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="0.01"
                                                   LargeChange="0.1"
                                                   Minimum="-2"
                                                   Maximum="2" />
                                            </StackPanel>

                                            <!-- Preset Julia values -->
                                            <TextBlock Text="Presets:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" />
                                            <StackPanel Spacing="4">
                                                <Button Content="Classic Spiral (-0.7, 0.27)" Click="JuliaPreset1_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="Dendrite (-0.8, 0.156)" Click="JuliaPreset2_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="San Marco Jewel (0.285, 0.01)" Click="JuliaPreset3_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="Paisley Swirl (-0.4, 0.6)" Click="JuliaPreset4_Click" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Hailstone Parameters (visible only when Fractal Type = Hailstone) -->
                                        <StackPanel Spacing="8"
                                            Visibility="{x:Bind ViewModel.IsHailstoneMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Hailstone Sequence" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Starting Point X" />
                                                <NumberBox Value="{x:Bind ViewModel.HailstoneStartX, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="1"
                                                   LargeChange="10"
                                                   Minimum="-1000"
                                                   Maximum="1000" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Starting Point Y" />
                                                <NumberBox Value="{x:Bind ViewModel.HailstoneStartY, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="1"
                                                   LargeChange="10"
                                                   Minimum="-1000"
                                                   Maximum="1000" />
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Max Iterations" />
                                                <NumberBox Value="{x:Bind ViewModel.HailstoneMaxIterations, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="10"
                                                   LargeChange="100"
                                                   Minimum="10"
                                                   Maximum="10000"
                                                   ToolTipService.ToolTip="Maximum steps to calculate before stopping" />
                                            </StackPanel>

                                            <!-- Display Options -->
                                            <TextBlock Text="Display Options:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" />

                                            <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstoneAxes, Mode=TwoWay}"
                                              Content="Axes"
                                              ToolTipService.ToolTip="Display coordinate axes and integer lattice grid" />

                                            <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstonePoints, Mode=TwoWay}"
                                              Content="Dots"
                                              ToolTipService.ToolTip="Display dots at trajectory points where segments meet" />

                                            <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstoneLabels, Mode=TwoWay}"
                                              Content="Point Labels"
                                              ToolTipService.ToolTip="Display (N, X, Y) coordinates at each point" />

                                            <CheckBox IsChecked="{x:Bind ViewModel.UseFixedHailstoneViewport, Mode=TwoWay}"
                                              Content="Use Fixed Viewport (±40, ±30)"
                                              ToolTipService.ToolTip="Use standard fixed bounds centered on origin, instead of fitting to sequence data" />

                                            <!-- Preset starting points -->
                                            <TextBlock Text="Presets:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0" />
                                            <StackPanel Spacing="4">
                                                <Button Content="Classic Cycle (-10, 6)" Click="HailstonePreset1_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="Origin (0, 0)" Click="HailstonePreset2_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="Large Test (100, 100)" Click="HailstonePreset3_Click" HorizontalAlignment="Stretch" />
                                                <Button Content="Negative (-20, -30)" Click="HailstonePreset4_Click" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                        </StackPanel>

                                        <MenuFlyoutSeparator />

                                        <!-- Rendering Quality -->
                                        <TextBlock Text="Rendering Quality" FontWeight="SemiBold" />

                                        <StackPanel Spacing="4"
                                            Visibility="{x:Bind ViewModel.SupportsMaxIterations, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Max Iterations" />
                                            <NumberBox
                                        Value="{x:Bind ViewModel.MaxIterations, Mode=TwoWay}"
                                        SmallChange="128"
                                        LargeChange="1024"
                                        Minimum="50"
                                        Maximum="50000"
                                        SpinButtonPlacementMode="Inline"
                                        ToolTipService.ToolTip="Higher values show more detail at deep zoom levels" />
                                        </StackPanel>

                                        <CheckBox
                                    IsChecked="{x:Bind ViewModel.AutoScaleIterations, Mode=TwoWay}"
                                    Content="Auto-scale iterations with zoom"
                                    Visibility="{x:Bind ViewModel.SupportsMaxIterations, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Automatically increase iteration count as you zoom deeper" />

                                        <TextBlock
                                    Text="{x:Bind ViewModel.IterationSuggestion, Mode=OneWay}"
                                    Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                    TextWrapping="Wrap"
                                    FontSize="12"
                                    Visibility="{x:Bind ViewModel.IterationSuggestion, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}" />

                                        <MenuFlyoutSeparator />

                                        <!-- Image Resolution -->
                                        <TextBlock Text="Image Resolution" FontWeight="SemiBold" />

                                        <Grid ColumnSpacing="4" RowSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Button Grid.Row="0" Grid.Column="0"
                                            Content="HD"
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="HD"
                                            ToolTipService.ToolTip="1280x720"
                                            Style="{x:Bind ViewModel.IsHDResolution, Mode=OneWay, Converter={StaticResource BoolToButtonStyleConverter}}"
                                            HorizontalAlignment="Stretch" />
                                            <Button Grid.Row="0" Grid.Column="1"
                                            Content="FHD"
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="FullHD"
                                            ToolTipService.ToolTip="1920x1080"
                                            Style="{x:Bind ViewModel.IsFullHDResolution, Mode=OneWay, Converter={StaticResource BoolToButtonStyleConverter}}"
                                            HorizontalAlignment="Stretch" />
                                            <Button Grid.Row="1" Grid.Column="0"
                                            Content="2K"
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="2K"
                                            ToolTipService.ToolTip="2560x1440"
                                            Style="{x:Bind ViewModel.Is2KResolution, Mode=OneWay, Converter={StaticResource BoolToButtonStyleConverter}}"
                                            HorizontalAlignment="Stretch" />
                                            <Button Grid.Row="1" Grid.Column="1"
                                            Content="4K"
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="4K"
                                            ToolTipService.ToolTip="3840x2160"
                                            Style="{x:Bind ViewModel.Is4KResolution, Mode=OneWay, Converter={StaticResource BoolToButtonStyleConverter}}"
                                            HorizontalAlignment="Stretch" />
                                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                            Content="4K+ (4096×2160)"
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="4K+"
                                            ToolTipService.ToolTip="4096x2160 - DCI 4K Cinema Standard"
                                            Style="{x:Bind ViewModel.Is4KPlusResolution, Mode=OneWay, Converter={StaticResource BoolToButtonStyleConverter}}"
                                            HorizontalAlignment="Stretch" />
                                        </Grid>

                                        <Button Content="📐 Match Window"
                                        Click="MatchWindowSize_Click"
                                        ToolTipService.ToolTip="Set resolution to match window size"
                                        HorizontalAlignment="Stretch" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Width" FontSize="12" />
                                            <NumberBox
                                        Value="{x:Bind ViewModel.ImageWidth, Mode=TwoWay}"
                                        SmallChange="100"
                                        LargeChange="640"
                                        Minimum="320"
                                        Maximum="7680"
                                        SpinButtonPlacementMode="Compact" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Height" FontSize="12" />
                                            <NumberBox
                                        Value="{x:Bind ViewModel.ImageHeight, Mode=TwoWay}"
                                        SmallChange="100"
                                        LargeChange="480"
                                        Minimum="240"
                                        Maximum="4320"
                                        SpinButtonPlacementMode="Compact" />
                                        </StackPanel>

                                        <TextBlock FontSize="11" Opacity="0.7" TextWrapping="Wrap">
                                    <Run Text="{x:Bind ViewModel.ImageWidth, Mode=OneWay}" />
                                    <Run Text="×" />
                                    <Run Text="{x:Bind ViewModel.ImageHeight, Mode=OneWay}" />
                                    <Run Text=" (" />
                                    <Run Text="{x:Bind ViewModel.TotalPixels, Mode=OneWay}" />
                                    <Run Text=" MP)" />
                                        </TextBlock>

                                        <MenuFlyoutSeparator />

                                        <!-- Display Options -->
                                        <TextBlock Text="Display Options" FontWeight="SemiBold" />

                                        <ToggleSwitch
                                    IsOn="{x:Bind ViewModel.ShowCoordinateAxes, Mode=TwoWay}"
                                    Header="Show Coordinate Axes"
                                    OnContent="Visible"
                                    OffContent="Hidden"
                                    ToolTipService.ToolTip="Display tick marks and coordinate labels on image borders" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabViewItem>

                            <!-- Colors Tab (Week 7) -->
                            <TabViewItem Header="Colors">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Highlight" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Colors - Color palettes and gradient controls" />
                                </ToolTipService.ToolTip>
                                <properties:ColorEditorView x:Name="ColorEditor" />
                            </TabViewItem>

                            <!-- Render Settings Tab (Week 7) -->
                            <TabViewItem Header="Render">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="RepeatAll" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Render - Rendering engine and performance settings" />
                                </ToolTipService.ToolTip>
                                <properties:RenderSettingsView x:Name="RenderSettingsView" />
                            </TabViewItem>

                            <!-- Info Tab -->
                            <TabViewItem Header="Info">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Help" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Info - Fractal information and personal notes" />
                                </ToolTipService.ToolTip>
                                <ScrollViewer Padding="16">
                                    <Grid>
                                        <!-- Content when fractal is selected -->
                                        <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.SelectedFractalInfo, Mode=OneWay, Converter={StaticResource InvertedNullToVisibilityConverter}}">
                                            <!-- Header -->
                                            <TextBlock Text="{x:Bind ViewModel.SelectedFractalInfo.DisplayName, Mode=OneWay, FallbackValue='Fractal Name'}"
                                                       FontWeight="SemiBold"
                                                       FontSize="18" />

                                            <TextBlock Text="{x:Bind ViewModel.SelectedFractalInfo.Category, Mode=OneWay, FallbackValue='Category'}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                            <MenuFlyoutSeparator />

                                            <!-- Description -->
                                            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedFractalInfo.Description, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                                                <TextBlock Text="Description" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFractalInfo.Description, Mode=OneWay}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>

                                            <!-- Formula -->
                                            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedFractalInfo.Formula, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                                                <TextBlock Text="Formula" FontWeight="SemiBold" FontSize="14" />
                                                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12"
                                                        Background="{ThemeResource LayerFillColorAltBrush}">
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedFractalInfo.Formula, Mode=OneWay}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </StackPanel>

                                            <!-- Visual Characteristics -->
                                            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedFractalInfo.VisualCharacteristics, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                                                <TextBlock Text="Visual Characteristics" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFractalInfo.VisualCharacteristics, Mode=OneWay}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>

                                            <!-- Discovery Info -->
                                            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedFractalInfo.DiscoveredBy, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                                                <TextBlock Text="Discovery" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="Discovered by " />
                                                    <Run Text="{x:Bind ViewModel.SelectedFractalInfo.DiscoveredBy, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text=" in " />
                                                    <Run Text="{x:Bind ViewModel.SelectedFractalInfo.DiscoveryYear, Mode=OneWay}" FontWeight="SemiBold" />
                                                </TextBlock>
                                            </StackPanel>

                                            <MenuFlyoutSeparator />

                                            <!-- User Notes Section -->
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Personal Notes" FontWeight="SemiBold" FontSize="14" />
                                                <TextBox Text="{x:Bind ViewModel.UserNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PlaceholderText="Add your notes about this fractal..."
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         MinHeight="100"
                                                         MaxHeight="200" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Content="Save Notes"
                                                            Command="{x:Bind ViewModel.SaveUserNotesCommand}"
                                                            Style="{StaticResource AccentButtonStyle}">
                                                        <Button.KeyboardAccelerators>
                                                            <KeyboardAccelerator Key="S" Modifiers="Control" />
                                                        </Button.KeyboardAccelerators>
                                                    </Button>
                                                    <Button Content="Clear Notes"
                                                            Command="{x:Bind ViewModel.ClearUserNotesCommand}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Empty state when no fractal is selected -->
                                        <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.SelectedFractalInfo, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                            <TextBlock Text="Fractal Information"
                                                       FontWeight="SemiBold"
                                                       FontSize="16" />
                                            <TextBlock Text="Select a fractal from the browser to see its description and properties."
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </TabViewItem>

                            <!-- Bookmarks Tab -->
                            <TabViewItem Header="Bookmarks">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Favorite" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Bookmarks - Save and manage favorite locations" />
                                </ToolTipService.ToolTip>
                                <ScrollViewer Padding="16">
                                    <StackPanel Spacing="12">
                                        <!-- Header -->
                                        <TextBlock Text="Bookmark Management"
                                                       FontWeight="SemiBold"
                                                       FontSize="16" />

                                        <TextBlock Text="Save and organize your favorite fractal locations. Click the Bookmarks button in the toolbar to manage your collection."
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                        <MenuFlyoutSeparator />

                                        <!-- Import/Export Section -->
                                        <TextBlock Text="Share Bookmarks"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />

                                        <TextBlock Text="Export your bookmarks to share with others, or import bookmarks from a file."
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Command="{x:Bind ViewModel.ExportBookmarksCommand}"
                                                    Style="{StaticResource AccentButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xEDE1;" FontSize="16" />
                                                    <TextBlock Text="Export Bookmarks" />
                                                </StackPanel>
                                            </Button>

                                            <Button Command="{x:Bind ViewModel.ImportBookmarksCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8B5;" FontSize="16" />
                                                    <TextBlock Text="Import Bookmarks" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <InfoBar
                                            IsOpen="True"
                                            Severity="Informational"
                                            IsClosable="False"
                                            Message="Exported files contain only your custom bookmarks, not the built-in presets." />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabViewItem>

                            <!-- Navigation History Tab (Week 8) -->
                            <TabViewItem Header="History">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Clock" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="History - Navigation history and undo/redo" />
                                </ToolTipService.ToolTip>
                                <ScrollViewer Padding="16">
                                    <StackPanel Spacing="12">
                                        <!-- Header -->
                                        <Grid>
                                            <TextBlock Text="Navigation History"
                                                       FontWeight="SemiBold"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                            <Button Content="Clear All"
                                                    Command="{x:Bind ViewModel.ClearNavigationHistoryCommand}"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    ToolTipService.ToolTip="Clear all navigation history" />
                                        </Grid>

                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Navigate through your fractal exploration history. Use " />
                                            <Run Text="Ctrl+Z" FontWeight="SemiBold" />
                                            <Run Text=" to undo and " />
                                            <Run Text="Ctrl+Y" FontWeight="SemiBold" />
                                            <Run Text=" to redo." />
                                        </TextBlock>

                                        <MenuFlyoutSeparator />

                                        <!-- History List -->
                                        <TextBlock FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Total entries: " />
                                            <Run Text="{x:Bind ViewModel.NavigationHistory.Count, Mode=OneWay}" />
                                        </TextBlock>

                                        <ListView ItemsSource="{x:Bind ViewModel.NavigationHistory, Mode=OneWay}"
                                                  SelectionMode="None"
                                                  MaxHeight="500">
                                            <ListView.ItemTemplate>
                                                <DataTemplate x:DataType="models:NavigationHistoryEntry">
                                                    <Grid Padding="8,12" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Entry Info -->
                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <TextBlock Text="{x:Bind Description}"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock FontSize="11"
                                                                       Opacity="0.7"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="{x:Bind CoordinateDisplay}" />
                                                            </TextBlock>
                                                            <TextBlock Text="{x:Bind TimeDisplay}"
                                                                       FontSize="10"
                                                                       Opacity="0.6" />
                                                        </StackPanel>

                                                        <!-- Promote to Bookmark Button -->
                                                        <Button Grid.Column="1"
                                                                Content="&#xE734;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                Command="{Binding ElementName=Page, Path=ViewModel.PromoteHistoryToBookmarkCommand}"
                                                                CommandParameter="{x:Bind}"
                                                                Style="{StaticResource SubtleButtonStyle}"
                                                                ToolTipService.ToolTip="Save as bookmark" />

                                                        <!-- Go Button -->
                                                        <Button Grid.Column="2"
                                                                Content="&#xE768;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                Click="HistoryEntry_Click"
                                                                Style="{StaticResource SubtleButtonStyle}"
                                                                ToolTipService.ToolTip="Jump to this state" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabViewItem>

                            <!-- Animation Tab (Week 12) -->
                            <TabViewItem Header="Animation">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Video" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Animation - Create zoom and pan animations" />
                                </ToolTipService.ToolTip>
                                <animation:AnimationControlPanel x:Name="AnimationPanel" />
                            </TabViewItem>

                            <!-- Settings Tab -->
                            <TabViewItem Header="Settings">
                                <TabViewItem.IconSource>
                                    <SymbolIconSource Symbol="Setting" />
                                </TabViewItem.IconSource>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="Settings - Application preferences and theme" />
                                </ToolTipService.ToolTip>
                                <settings:SettingsView />
                            </TabViewItem>
                        </TabView>
                    </Grid>

                    <!-- Collapsed Properties Panel Button -->
                    <Button Grid.Column="4"
                            Visibility="{x:Bind ViewModel.IsPropertiesPanelVisible, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                            Content="&#xE76B;"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{x:Bind ViewModel.TogglePropertiesPanelCommand}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Margin="4"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Expand properties panel (Ctrl+P)"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1" />
        </Grid>

        <!-- Streamlined Status Bar -->
        <Grid Grid.Row="2"
                          Background="{ThemeResource SystemControlAcrylicElementBrush}"
                          Padding="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: Visualization name -->
            <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   FontWeight="SemiBold"
                                   Text="{x:Bind ViewModel.CurrentVisualizationName, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.CurrentVisualizationName, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}" />

            <!-- Left-Center: Status message -->
            <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

            <!-- Center: View dimensions in fractal coordinates -->
            <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Opacity="0.8"
                                   FontSize="12">
                            <Run Text="View: " />
                            <Run Text="{x:Bind ViewModel.CurrentViewWidth, Mode=OneWay}" />
                            <Run Text=" × " />
                            <Run Text="{x:Bind ViewModel.CurrentViewHeight, Mode=OneWay}" />
                            <Run Text=" (fractal units)" />
                            <Run Text="{x:Bind ViewModel.DeepZoomIndicator, Mode=OneWay}" Foreground="#8B4513" FontWeight="Bold" />
            </TextBlock>

            <!-- Right: Render time -->
            <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   FontSize="12">
                            <Run Text="⏱️ " />
                            <Run Text="{x:Bind ViewModel.LastRenderTime, Mode=OneWay}" />
            </TextBlock>
        </Grid>
    </Grid>
</Page>
