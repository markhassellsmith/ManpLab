<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="ManpWinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ManpWinUI.Views"
    xmlns:vm="using:ManpWinUI.ViewModels"
    xmlns:models="using:ManpWinUI.Models"
    xmlns:browser="using:ManpWinUI.Views.Browser"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    KeyDown="Page_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Toolbar -->
            <RowDefinition Height="*" />
            <!-- Main Content (Fractal + Side Panel) -->
            <RowDefinition Height="Auto" />
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton
                Icon="Play"
                Label="Render"
                Command="{x:Bind ViewModel.RenderCommand}"
                IsEnabled="{x:Bind ViewModel.IsRendering, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Render fractal (Ctrl+R)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton
                Icon="Refresh"
                Label="Reset View"
                Command="{x:Bind ViewModel.ResetViewCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Reset to default view (Space)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Icon="ZoomIn"
                Label="Zoom In"
                Command="{x:Bind ViewModel.ZoomInCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Zoom in 2x (+)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton
                Icon="ZoomOut"
                Label="Zoom Out"
                Command="{x:Bind ViewModel.ZoomOutCommand}">
                <ToolTipService.ToolTip>
                    <ToolTip Content="Zoom out 2x (-)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarButton Label="Pan">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7C2;" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Pan with arrow keys: ← → ↑ ↓" IsEnabled="False" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Or right-click and drag on image" IsEnabled="False" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Pan view (Arrow keys or right-click drag)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Icon="Save"
                Label="Save Image"
                Click="SaveImage_Click"
                IsEnabled="{x:Bind ViewModel.FractalImage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Save as PNG" Icon="Save" Click="SavePNG_Click" />
                        <MenuFlyoutItem Text="Save as JPEG" Click="SaveJPEG_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE91B;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Save as SVG (Hailstone only)" 
                                       Click="SaveSVG_Click"
                                       Visibility="{x:Bind ViewModel.IsHailstoneMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE7C3;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Copy to Clipboard" Icon="Copy" Click="CopyToClipboard_Click" />
                    </MenuFlyout>
                </AppBarButton.Flyout>
                <ToolTipService.ToolTip>
                    <ToolTip Content="Save or copy fractal image (Ctrl+S)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                Label="Bookmarks"
                Command="{x:Bind ViewModel.ToggleBookmarksPanelCommand}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE734;" />
                </AppBarButton.Icon>
                <ToolTipService.ToolTip>
                    <ToolTip Content="View and manage fractal bookmarks (B)" />
                </ToolTipService.ToolTip>
            </AppBarButton>
        </CommandBar>

        <!-- Main Content Area -->
        <SplitView Grid.Row="1" 
                   IsPaneOpen="{x:Bind ViewModel.IsBookmarksPanelOpen, Mode=TwoWay}"
                   DisplayMode="Overlay"
                   PanePlacement="Left"
                   OpenPaneLength="350"
                   CompactPaneLength="0">

            <!-- Bookmarks Panel (Pane) -->
            <SplitView.Pane>
                <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <ScrollViewer Padding="16">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Bookmarks" 
                                          FontWeight="Bold" 
                                          FontSize="20" 
                                          VerticalAlignment="Center"/>
                                <Button Content="&#xE711;" 
                                       FontFamily="Segoe MDL2 Assets"
                                       Command="{x:Bind ViewModel.ToggleBookmarksPanelCommand}"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource SubtleButtonStyle}"
                                       ToolTipService.ToolTip="Close bookmarks"/>
                            </Grid>

                            <MenuFlyoutSeparator />

                            <!-- Save Current View -->
                            <StackPanel Spacing="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12" CornerRadius="8">
                                <TextBlock Text="Save Current View" FontWeight="SemiBold" />
                                <TextBox x:Name="NewBookmarkNameTextBox" 
                                        PlaceholderText="Enter bookmark name..."
                                        Header="Name"/>
                                <Button Command="{x:Bind ViewModel.SaveCurrentAsBookmarkCommand}"
                                       CommandParameter="{x:Bind NewBookmarkNameTextBox.Text, Mode=OneWay}"
                                       HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                                        <TextBlock Text="Save Bookmark"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <MenuFlyoutSeparator />

                            <!-- Bookmarks List -->
                            <TextBlock Text="Saved Locations" FontWeight="SemiBold" />

                            <ListView ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}"
                                     SelectedItem="{x:Bind ViewModel.SelectedBookmark, Mode=TwoWay}"
                                     SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FractalBookmark">
                                        <Grid Padding="8" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Favorite Star -->
                                            <FontIcon Grid.Column="0"
                                                     Glyph="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToStarGlyphConverter}}"
                                                     FontSize="16"
                                                     Foreground="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToStarColorConverter}}"/>

                                            <!-- Bookmark Info -->
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind CoordinateDisplay}" 
                                                          FontSize="11" 
                                                          Opacity="0.7"
                                                          TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind Description}" 
                                                          FontSize="10" 
                                                          Opacity="0.6"
                                                          TextWrapping="Wrap"
                                                          Visibility="{x:Bind Description, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}"/>
                                            </StackPanel>

                                            <!-- Load Button -->
                                            <Button Grid.Column="2"
                                                   Content="&#xE768;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Command="{Binding ElementName=Page, Path=ViewModel.LoadBookmarkCommand}"
                                                   CommandParameter="{x:Bind}"
                                                   Style="{StaticResource SubtleButtonStyle}"
                                                   ToolTipService.ToolTip="Load this bookmark"/>

                                            <!-- Delete Button (not for presets) -->
                                            <Button Grid.Column="3"
                                                   Content="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Command="{Binding ElementName=Page, Path=ViewModel.DeleteBookmarkCommand}"
                                                   CommandParameter="{x:Bind}"
                                                   Style="{StaticResource SubtleButtonStyle}"
                                                   Visibility="{x:Bind IsPreset, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                                   ToolTipService.ToolTip="Delete bookmark"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>

            <!-- Main Content (Content) -->
            <SplitView.Content>
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <!-- Browser Panel - wider to show full names -->
                <ColumnDefinition Width="*" />
                <!-- Fractal Display -->
                <ColumnDefinition Width="350" />
                <!-- Properties Panel -->
            </Grid.ColumnDefinitions>

            <!-- Browser Panel -->
            <Grid Grid.Column="0"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,1,0">
                <browser:FractalBrowserView />
            </Grid>

            <!-- Fractal Canvas -->
            <Grid Grid.Column="1"
                  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                  PointerPressed="FractalImage_PointerPressed"
                  PointerMoved="FractalImage_PointerMoved"
                  PointerReleased="FractalImage_PointerReleased"
                  PointerWheelChanged="FractalImage_PointerWheelChanged">
                <!-- Fractal Image Display -->
                <Viewbox x:Name="FractalViewbox" Stretch="Fill" SizeChanged="FractalViewbox_SizeChanged">
                    <Image
                        x:Name="FractalImage"
                        Source="{x:Bind ViewModel.FractalImage, Mode=OneWay}"
                        Stretch="None" />
                </Viewbox>

                <!-- Selection Rectangle Overlay -->
                <Canvas x:Name="SelectionCanvas" Canvas.ZIndex="10">
                    <Rectangle
                        x:Name="SelectionRectangle"
                        Stroke="Cyan"
                        StrokeThickness="3"
                        Fill="#40FFFFFF"
                        Visibility="Collapsed"
                        StrokeDashArray="5,3">
                        <Rectangle.Shadow>
                            <ThemeShadow />
                        </Rectangle.Shadow>
                </Rectangle>
            </Canvas>

            <!-- Coordinate Axes Overlay (for Mandelbrot/Julia only, not for Hailstone) -->
            <Canvas x:Name="CoordinateAxesCanvas" 
                    Canvas.ZIndex="5"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.ShowMandelbrotAxes, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    SizeChanged="CoordinateAxesCanvas_SizeChanged">
            </Canvas>

            <!-- Hailstone Labels Overlay -->
            <Canvas x:Name="HailstoneLabelsCanvas" 
                    Canvas.ZIndex="6"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.IsHailstoneMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    SizeChanged="HailstoneLabelsCanvas_SizeChanged">
            </Canvas>

            <!-- Welcome Overlay (shown when no fractal is rendered) -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                Visibility="{x:Bind ViewModel.FractalImage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock
                    Text="ManpLab - Fractal Explorer"
                    FontSize="32"
                    FontWeight="Bold"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Phase 3: WinUI MVVM Architecture"
                    FontSize="16"
                    Opacity="0.7"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Adjust parameters in the side panel and click 'Render' to generate your first fractal!"
                    FontSize="14"
                    Opacity="0.6"
                    HorizontalAlignment="Center"
                    TextWrapping="Wrap"
                    MaxWidth="400" />
            </StackPanel>

                            <!-- Progress Overlay -->
                            <Grid
                                Background="{ThemeResource SystemControlAcrylicElementBrush}"
                                Visibility="{x:Bind ViewModel.IsRendering, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="16">
                                    <ProgressRing
                                        IsActive="{x:Bind ViewModel.IsRendering, Mode=OneWay}"
                                        Width="60"
                                        Height="60" />
                                    <TextBlock
                                        Text="Rendering fractal..."
                                        FontSize="16"
                                        HorizontalAlignment="Center" />
                                    <ProgressBar
                                        Value="{x:Bind ViewModel.RenderProgress, Mode=OneWay}"
                                        Width="300"
                                        Maximum="100" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Properties Panel with Tabs -->
                        <Grid Grid.Column="2"
                              Background="{ThemeResource LayerFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="1,0,0,0">
                            <TabView>
                                <!-- Parameters Tab -->
                                <TabViewItem Header="Parameters">
                                    <TabViewItem.IconSource>
                                        <SymbolIconSource Symbol="Setting" />
                                    </TabViewItem.IconSource>
                                    <ScrollViewer Padding="16">
                                        <StackPanel Spacing="12">
                                            <!-- Fractal Type Selection -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Fractal Type" FontWeight="SemiBold" />
                                    <ComboBox
                                        SelectedItem="{x:Bind ViewModel.SelectedFractalType, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch">
                                        <!-- Classic Fractals -->
                                        <x:String>Mandelbrot</x:String>
                                        <x:String>BurningShip</x:String>
                                        <x:String>Tricorn</x:String>
                                        <x:String>Phoenix</x:String>
                                        <!-- Multibrot Family -->
                                        <x:String>Multibrot3</x:String>
                                        <x:String>Multibrot4</x:String>
                                        <x:String>Multibrot5</x:String>
                                        <!-- Newton Method -->
                                        <x:String>Newton</x:String>
                                        <x:String>Nova</x:String>
                                        <!-- Magnet Fractals -->
                                        <x:String>Magnet1</x:String>
                                        <x:String>Magnet2</x:String>
                                        <!-- Julia Presets -->
                                        <x:String>JuliaSanMarco</x:String>
                                        <x:String>JuliaDouadyRabbit</x:String>
                                        <x:String>JuliaSiegelDisk</x:String>
                                        <!-- Hailstone (special) -->
                                        <x:String>Hailstone</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <MenuFlyoutSeparator />

                                <!-- Iteration Mode (Standard/Julia) -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Iteration Mode" FontWeight="SemiBold" />
                                    <ComboBox
                                        SelectedItem="{x:Bind ViewModel.SelectedIterationMode, Mode=TwoWay}"
                                        HorizontalAlignment="Stretch">
                                        <x:String>Standard</x:String>
                                        <x:String>Julia</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Julia Parameters (visible only when Iteration Mode = Julia) -->
                                <StackPanel Spacing="8" 
                                            Visibility="{x:Bind ViewModel.IsJuliaMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Julia Constant (c)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Real Part (c_x)"/>
                                        <NumberBox Value="{x:Bind ViewModel.JuliaCX, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="0.01"
                                                   LargeChange="0.1"
                                                   Minimum="-2"
                                                   Maximum="2"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Imaginary Part (c_y)"/>
                                        <NumberBox Value="{x:Bind ViewModel.JuliaCY, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="0.01"
                                                   LargeChange="0.1"
                                                   Minimum="-2"
                                                   Maximum="2"/>
                                    </StackPanel>

                                    <!-- Preset Julia values -->
                                    <TextBlock Text="Presets:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                                    <StackPanel Spacing="4">
                                        <Button Content="Classic Spiral (-0.7, 0.27)" Click="JuliaPreset1_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="Dendrite (-0.8, 0.156)" Click="JuliaPreset2_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="San Marco Jewel (0.285, 0.01)" Click="JuliaPreset3_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="Paisley Swirl (-0.4, 0.6)" Click="JuliaPreset4_Click" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Hailstone Parameters (visible only when Fractal Type = Hailstone) -->
                                <StackPanel Spacing="8" 
                                            Visibility="{x:Bind ViewModel.IsHailstoneMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Hailstone Sequence" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Starting Point X"/>
                                        <NumberBox Value="{x:Bind ViewModel.HailstoneStartX, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="1"
                                                   LargeChange="10"
                                                   Minimum="-1000"
                                                   Maximum="1000"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Starting Point Y"/>
                                        <NumberBox Value="{x:Bind ViewModel.HailstoneStartY, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="1"
                                                   LargeChange="10"
                                                   Minimum="-1000"
                                                   Maximum="1000"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Max Iterations"/>
                                        <NumberBox Value="{x:Bind ViewModel.HailstoneMaxIterations, Mode=TwoWay}"
                                                   SpinButtonPlacementMode="Inline"
                                                   SmallChange="10"
                                                   LargeChange="100"
                                                   Minimum="10"
                                                   Maximum="10000"
                                                   ToolTipService.ToolTip="Maximum steps to calculate before stopping"/>
                                    </StackPanel>

                                    <!-- Display Options -->
                                    <TextBlock Text="Display Options:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>

                                    <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstoneAxes, Mode=TwoWay}"
                                              Content="Axes"
                                              ToolTipService.ToolTip="Display coordinate axes and integer lattice grid"/>

                                    <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstonePoints, Mode=TwoWay}"
                                              Content="Dots"
                                              ToolTipService.ToolTip="Display dots at trajectory points where segments meet"/>

                                    <CheckBox IsChecked="{x:Bind ViewModel.ShowHailstoneLabels, Mode=TwoWay}"
                                              Content="Point Labels"
                                              ToolTipService.ToolTip="Display (N, X, Y) coordinates at each point"/>

                                    <CheckBox IsChecked="{x:Bind ViewModel.UseFixedHailstoneViewport, Mode=TwoWay}"
                                              Content="Use Fixed Viewport (±40, ±30)"
                                              ToolTipService.ToolTip="Use standard fixed bounds centered on origin, instead of fitting to sequence data"/>

                                    <!-- Preset starting points -->
                                    <TextBlock Text="Presets:" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                                    <StackPanel Spacing="4">
                                        <Button Content="Classic Cycle (-10, 6)" Click="HailstonePreset1_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="Origin (0, 0)" Click="HailstonePreset2_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="Large Test (100, 100)" Click="HailstonePreset3_Click" HorizontalAlignment="Stretch"/>
                                        <Button Content="Negative (-20, -30)" Click="HailstonePreset4_Click" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </StackPanel>

                                <MenuFlyoutSeparator />

                                <!-- Coordinates -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Center X" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.CenterX, Mode=TwoWay}"
                                        SmallChange="0.1"
                                        LargeChange="1.0"
                                        SpinButtonPlacementMode="Inline" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Center Y" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.CenterY, Mode=TwoWay}"
                                        SmallChange="0.1"
                                        LargeChange="1.0"
                                        SpinButtonPlacementMode="Inline" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Zoom Level" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.Zoom, Mode=TwoWay}"
                                        SmallChange="0.5"
                                        LargeChange="2.0"
                                        Minimum="0.001"
                                        SpinButtonPlacementMode="Inline" />
                                </StackPanel>

                                <MenuFlyoutSeparator />

                                <!-- Rendering Quality -->
                                <TextBlock Text="Rendering Quality" FontWeight="SemiBold" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Max Iterations" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.MaxIterations, Mode=TwoWay}"
                                        SmallChange="128"
                                        LargeChange="1024"
                                        Minimum="50"
                                        Maximum="50000"
                                        SpinButtonPlacementMode="Inline"
                                        ToolTipService.ToolTip="Higher values show more detail at deep zoom levels" />
                                </StackPanel>

                                <CheckBox 
                                    IsChecked="{x:Bind ViewModel.AutoScaleIterations, Mode=TwoWay}"
                                    Content="Auto-scale iterations with zoom"
                                    ToolTipService.ToolTip="Automatically increase iteration count as you zoom deeper" />

                                <TextBlock 
                                    Text="{x:Bind ViewModel.IterationSuggestion, Mode=OneWay}"
                                    Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                    TextWrapping="Wrap"
                                    FontSize="12"
                                    Visibility="{x:Bind ViewModel.IterationSuggestion, Mode=OneWay, Converter={StaticResource EmptyStringToCollapsedConverter}}" />

                                <MenuFlyoutSeparator />

                                <!-- Image Resolution -->
                                <TextBlock Text="Image Resolution" FontWeight="SemiBold" />

                                <Grid ColumnSpacing="4" RowSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" 
                                            Content="HD" 
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="HD"
                                            ToolTipService.ToolTip="1280x720"
                                            HorizontalAlignment="Stretch" />
                                    <Button Grid.Row="0" Grid.Column="1" 
                                            Content="FHD" 
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="FullHD"
                                            ToolTipService.ToolTip="1920x1080"
                                            HorizontalAlignment="Stretch" />
                                    <Button Grid.Row="1" Grid.Column="0" 
                                            Content="2K" 
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="2K"
                                            ToolTipService.ToolTip="2560x1440"
                                            HorizontalAlignment="Stretch" />
                                    <Button Grid.Row="1" Grid.Column="1" 
                                            Content="4K" 
                                            Command="{x:Bind ViewModel.SetResolutionCommand}"
                                            CommandParameter="4K"
                                            ToolTipService.ToolTip="3840x2160"
                                            Style="{StaticResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch" />
                                </Grid>

                                <Button Content="📐 Match Window" 
                                        Click="MatchWindowSize_Click"
                                        ToolTipService.ToolTip="Set resolution to match window size"
                                        HorizontalAlignment="Stretch" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Width" FontSize="12" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.ImageWidth, Mode=TwoWay}"
                                        SmallChange="100"
                                        LargeChange="640"
                                        Minimum="320"
                                        Maximum="7680"
                                        SpinButtonPlacementMode="Compact" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Height" FontSize="12" />
                                    <NumberBox
                                        Value="{x:Bind ViewModel.ImageHeight, Mode=TwoWay}"
                                        SmallChange="100"
                                        LargeChange="480"
                                        Minimum="240"
                                        Maximum="4320"
                                        SpinButtonPlacementMode="Compact" />
                                </StackPanel>

                                <TextBlock FontSize="11" Opacity="0.7" TextWrapping="Wrap">
                                    <Run Text="{x:Bind ViewModel.ImageWidth, Mode=OneWay}" />
                                    <Run Text="×" />
                                    <Run Text="{x:Bind ViewModel.ImageHeight, Mode=OneWay}" />
                                    <Run Text=" (" />
                                    <Run Text="{x:Bind ViewModel.TotalPixels, Mode=OneWay}" />
                                    <Run Text=" MP)" />
                                </TextBlock>

                                <MenuFlyoutSeparator />

                                <!-- Display Options -->
                                <TextBlock Text="Display Options" FontWeight="SemiBold" />

                                <ToggleSwitch 
                                    IsOn="{x:Bind ViewModel.ShowCoordinateAxes, Mode=TwoWay}"
                                    Header="Show Coordinate Axes"
                                    OnContent="Visible"
                                    OffContent="Hidden"
                                    ToolTipService.ToolTip="Display tick marks and coordinate labels on image borders" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>

                                <!-- Colors Tab -->
                                <TabViewItem Header="Colors">
                                    <TabViewItem.IconSource>
                                        <SymbolIconSource Symbol="Highlight" />
                                    </TabViewItem.IconSource>
                                    <ScrollViewer Padding="16">
                                        <StackPanel Spacing="12">
                                            <!-- Color Palette -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Color Palette" FontWeight="SemiBold" />
                                                <ComboBox
                                                    SelectedItem="{x:Bind ViewModel.SelectedPalette, Mode=TwoWay}"
                                                    HorizontalAlignment="Stretch">
                                                    <x:String>Grayscale</x:String>
                                                    <x:String>Classic</x:String>
                                                    <x:String>Fire</x:String>
                                                    <x:String>Ocean</x:String>
                                                    <x:String>Rainbow</x:String>
                                                    <x:String>Psychedelic</x:String>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>

                                <!-- Info Tab -->
                                <TabViewItem Header="Info">
                                    <TabViewItem.IconSource>
                                        <SymbolIconSource Symbol="Help" />
                                    </TabViewItem.IconSource>
                                    <ScrollViewer Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Fractal Information" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="16" />
                                            <TextBlock Text="Select a fractal from the browser to see its description and properties."
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Week 5: Dynamic fractal metadata will appear here"
                                                       FontSize="11"
                                                       FontStyle="Italic"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>

                                <!-- Bookmarks Tab -->
                                <TabViewItem Header="Bookmarks">
                                    <TabViewItem.IconSource>
                                        <SymbolIconSource Symbol="Favorite" />
                                    </TabViewItem.IconSource>
                                    <ScrollViewer Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Bookmark Management" 
                                                       FontWeight="SemiBold" 
                                                       FontSize="16" />
                                            <TextBlock Text="Use the Bookmarks button in the toolbar to manage saved locations."
                                                       TextWrapping="Wrap"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="Future: Bookmarks will be managed here instead of overlay panel"
                                                       FontSize="11"
                                                       FontStyle="Italic"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>
                            </TabView>
                        </Grid>
            </Grid>
            </SplitView.Content>
        </SplitView>

        <!-- Streamlined Status Bar -->
        <Grid Grid.Row="2"
                          Background="{ThemeResource SystemControlAcrylicElementBrush}"
                          Padding="12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Status message -->
                        <TextBlock Grid.Column="0" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,16,0"
                                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

                        <!-- Center: View dimensions in fractal coordinates -->
                        <TextBlock Grid.Column="1" 
                                   VerticalAlignment="Center" 
                                   Opacity="0.8"
                                   FontSize="12">
                            <Run Text="View: " />
                            <Run Text="{x:Bind ViewModel.CurrentViewWidth, Mode=OneWay}" />
                            <Run Text=" × " />
                            <Run Text="{x:Bind ViewModel.CurrentViewHeight, Mode=OneWay}" />
                            <Run Text=" (fractal units)" />
                        </TextBlock>

                        <!-- Right: Render time -->
                        <TextBlock Grid.Column="2" 
                                   VerticalAlignment="Center" 
                                   Opacity="0.7"
                                   FontSize="12">
                            <Run Text="⏱️ " />
                            <Run Text="{x:Bind ViewModel.LastRenderTime, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>
                </Grid>
            </Page>