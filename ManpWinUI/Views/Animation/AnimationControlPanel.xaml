<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ManpWinUI.Views.Animation.AnimationControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:animation="using:ManpWinUI.Models.Animation"
    xmlns:converters="using:ManpWinUI.Converters"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="16" Spacing="12">

            <!-- Header -->
            <TextBlock 
                Text="Animation Creator" 
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,0,0,8"/>

            <!-- Current View Info -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Current Fractal View" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock 
                        FontSize="11" 
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap">
                        <Run Text="Your animation will use the current fractal type, colors, and all custom parameters from the main view."/>
                    </TextBlock>
                    <Button 
                        Content="↻ Sync Start Position from Current View"
                        Click="SyncFromCurrentViewButton_Click"
                        HorizontalAlignment="Stretch"
                        Margin="0,8,0,0"
                        Style="{StaticResource AccentButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Animation Type Selector -->
            <StackPanel Spacing="8">
                <TextBlock Text="Animation Type" FontWeight="SemiBold"/>
                <ComboBox 
                    x:Name="AnimationTypeComboBox"
                    ItemsSource="{x:Bind ViewModel.AvailableAnimationTypes, Mode=OneTime}"
                    SelectedItem="{x:Bind ViewModel.SelectedAnimationType, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="Select animation type"/>
            </StackPanel>

            <!-- Zoom Settings (visible when Zoom selected) -->
            <StackPanel 
                Spacing="8">

                <TextBlock Text="Zoom Settings" FontWeight="SemiBold" Margin="0,8,0,0"/>

                <!-- Zoom Speed Preset Selector -->
                <StackPanel>
                    <TextBlock Text="Zoom Speed" FontSize="12"/>
                    <ComboBox 
                        ItemsSource="{x:Bind ViewModel.AvailableZoomSpeedPresets, Mode=OneTime}"
                        SelectedItem="{x:Bind ViewModel.SelectedZoomSpeed, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Select zoom speed"/>
                    <TextBlock 
                        FontSize="11" 
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap"
                        Margin="0,4,0,0">
                        <Run Text="Tip: 'Medium' = 1000x zoom. Choose 'Very Slow' or 'Slow' for smoother animations."/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock Text="Start Zoom" FontSize="12"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.StartZoom, Mode=TwoWay}"
                            Minimum="0.1"
                            Maximum="1000000"
                            SpinButtonPlacementMode="Inline"
                            Width="150"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="End Zoom" FontSize="12"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.EndZoom, Mode=TwoWay}"
                            Minimum="0.1"
                            Maximum="1000000"
                            SpinButtonPlacementMode="Inline"
                            Width="150"/>
                    </StackPanel>
                </StackPanel>

                <!-- Zoom Ratio Display -->
                <TextBlock 
                    FontSize="11" 
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Margin="0,0,0,0">
                    <Run Text="Total Magnification: "/>
                    <Run Text="{x:Bind ViewModel.ZoomRatioDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>

            <!-- Parameter Settings (visible when Parameter selected) -->
            <StackPanel 
                Spacing="8">

                <TextBlock Text="Parameter Settings" FontWeight="SemiBold" Margin="0,8,0,0"/>

                <StackPanel>
                    <TextBlock Text="Parameter Name" FontSize="12"/>
                    <TextBox 
                        Text="{x:Bind ViewModel.ParameterToAnimate, Mode=TwoWay}"
                        PlaceholderText="e.g., exponent, power"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock Text="Start Value" FontSize="12"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.StartParameterValue, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="End Value" FontSize="12"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.EndParameterValue, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Pan Settings (visible when Pan selected) -->
            <StackPanel 
                Spacing="8">

                <TextBlock Text="Pan Settings" FontWeight="SemiBold" Margin="0,8,0,0"/>

                <TextBlock Text="Start Position" FontSize="12"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock Text="Center X" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.StartCenterX, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"
                            SmallChange="0.1"
                            LargeChange="1.0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Center Y" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.StartCenterY, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"
                            SmallChange="0.1"
                            LargeChange="1.0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="End Position" FontSize="12" Margin="0,8,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock Text="Center X" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.EndCenterX, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"
                            SmallChange="0.1"
                            LargeChange="1.0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Center Y" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <NumberBox 
                            Value="{x:Bind ViewModel.EndCenterY, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline"
                            Width="150"
                            SmallChange="0.1"
                            LargeChange="1.0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

            <!-- General Animation Settings -->
            <TextBlock Text="Animation Settings" FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel>
                    <TextBlock Text="Duration (seconds)" FontSize="12"/>
                    <NumberBox 
                        Value="{x:Bind ViewModel.DurationSeconds, Mode=TwoWay}"
                        Minimum="0.1"
                        Maximum="300"
                        SpinButtonPlacementMode="Inline"
                        Width="150"
                        SmallChange="0.5"
                        LargeChange="5"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Frame Rate (fps)" FontSize="12"/>
                    <ComboBox 
                        SelectedValue="{x:Bind ViewModel.FrameRate, Mode=TwoWay}"
                        Width="150">
                        <x:Int32>24</x:Int32>
                        <x:Int32>30</x:Int32>
                        <x:Int32>60</x:Int32>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Easing Function" FontSize="12"/>
                <ComboBox 
                    ItemsSource="{x:Bind ViewModel.AvailableEasingFunctions, Mode=OneTime}"
                    SelectedItem="{x:Bind ViewModel.SelectedEasing, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

            <!-- Export Settings -->
            <TextBlock Text="Export Settings" FontWeight="SemiBold"/>

            <StackPanel>
                <TextBlock Text="Format" FontSize="12"/>
                <ComboBox 
                    ItemsSource="{x:Bind ViewModel.AvailableExportFormats, Mode=OneTime}"
                    SelectedItem="{x:Bind ViewModel.SelectedExportFormat, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Output Path" FontSize="12"/>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox 
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.OutputPath, Mode=TwoWay}"
                        PlaceholderText="Select output file..."/>

                    <Button 
                        Grid.Column="1"
                        Content="Browse..."
                        Click="BrowseButton_Click"/>
                </Grid>

                <!-- Output path status indicator -->
                <TextBlock 
                    Text="{x:Bind ViewModel.OutputPathStatus, Mode=OneWay}"
                    FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Margin="0,4,0,0"/>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

            <!-- Render Button and Progress -->
            <StackPanel Spacing="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button 
                        Grid.Column="0"
                        Content="Render Animation"
                        Command="{x:Bind ViewModel.RenderAnimationCommand}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"/>

                    <Button 
                        Grid.Column="1"
                        Content="Cancel"
                        Command="{x:Bind ViewModel.CancelAnimationCommand}"
                        IsEnabled="{x:Bind ViewModel.IsRendering, Mode=OneWay}"/>
                </Grid>

                <!-- Progress Indicator -->
                <StackPanel 
                    Spacing="8"
                    Visibility="{x:Bind (Visibility)ViewModel.IsRendering, Mode=OneWay}">

                    <ProgressBar 
                        Value="{x:Bind ViewModel.RenderProgress, Mode=OneWay}"
                        Maximum="100"
                        ShowError="False"
                        ShowPaused="False"/>

                    <!-- Line 1: Rendering Frame X / Y -->
                    <TextBlock 
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="{x:Bind ViewModel.RenderPhase, Mode=OneWay}"/>
                        <Run Text="Frame"/>
                        <Run Text="{x:Bind ViewModel.CurrentFrame, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{x:Bind ViewModel.TotalFrames, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Line 2: Rendering Time elapsed / total estimated -->
                    <TextBlock 
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="Rendering Time"/>
                        <Run Text="{x:Bind ViewModel.ElapsedTime, Mode=OneWay, Converter={StaticResource TimeSpanToStringConverter}}"/>
                        <Run Text="/"/>
                        <Run Text="{x:Bind ViewModel.TotalEstimatedTime, Mode=OneWay, Converter={StaticResource TimeSpanToStringConverter}}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Status Message (when not rendering) -->
                <StackPanel Spacing="4">
                    <!-- Error messages or progress text (selectable) -->
                    <TextBox 
                        Text="{x:Bind ViewModel.RenderStatusMessage, Mode=OneWay}"
                        FontSize="12"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        IsReadOnly="True"
                        BorderThickness="0"
                        Background="Transparent"
                        IsSpellCheckEnabled="False"
                        Padding="0"
                        Visibility="{x:Bind (Visibility)ViewModel.HasCompletedFile, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>

                    <!-- Clickable full file path when complete -->
                    <HyperlinkButton 
                        Content="{x:Bind ViewModel.RenderStatusMessage, Mode=OneWay}"
                        Command="{x:Bind ViewModel.OpenCompletedFileCommand}"
                        Visibility="{x:Bind (Visibility)ViewModel.HasCompletedFile, Mode=OneWay}"
                        FontSize="12"
                        Padding="0"/>
                </StackPanel>
            </StackPanel>

            <!-- Info Panel -->
            <InfoBar
                Title="Animation Feature Preview"
                Message="This is the Phase 1 MVP of the animation system. Full integration with MainViewModel and additional animation types coming in Phase 2."
                Severity="Informational"
                IsOpen="True"
                IsClosable="True"
                Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
