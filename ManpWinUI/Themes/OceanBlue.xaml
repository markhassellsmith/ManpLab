<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ocean Blue Theme - Maritime color palette -->
    <!-- This theme is based on Light theme with custom background colors -->

    <!-- Central Canvas Area -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#C8DFF0" />

    <!-- Toolbar / CommandBar - Use WinUI 3's proper resource keys -->
    <SolidColorBrush x:Key="AppBarBackground" Color="#B3D9F0" />
    <SolidColorBrush x:Key="CommandBarBackground" Color="#B3D9F0" />

    <!-- Ensure dark text on light blue background -->
    <SolidColorBrush x:Key="AppBarForeground" Color="#000000" />
    <SolidColorBrush x:Key="AppBarButtonForeground" Color="#000000" />
    <SolidColorBrush x:Key="AppBarButtonForegroundPointerOver" Color="#000000" />
    <SolidColorBrush x:Key="AppBarButtonForegroundPressed" Color="#000000" />

    <!-- Side Panels -->
    <SolidColorBrush x:Key="SidePanelBackgroundBrush" Color="#E8F4F8" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#D8E8F3" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#E8F4F8" />

    <!-- Accent Color -->
    <Color x:Key="SystemAccentColor">#4A90E2</Color>
</ResourceDictionary>
