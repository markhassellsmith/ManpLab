<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Ocean Blue Theme -->
    
    <!-- Central Canvas Area -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#C8DFF0" />
    
    <!-- Toolbar / CommandBar -->
    <SolidColorBrush x:Key="CommandBarBackground" Color="#B3D9F0" />
    <SolidColorBrush x:Key="AppBarBackgroundThemeBrush" Color="#B3D9F0" />
    
    <!-- Side Panels -->
    <SolidColorBrush x:Key="SidePanelBackgroundBrush" Color="#E8F4F8" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#D8E8F3" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#E8F4F8" />
    
    <!-- Accent Color -->
    <Color x:Key="SystemAccentColor">#4A90E2</Color>
</ResourceDictionary>
